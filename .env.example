# ============================================
# Tawjih V4 — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# PostgreSQL
POSTGRES_USER=tawjihi
POSTGRES_PASSWORD=tawjihi_secure_pwd_2026
POSTGRES_DB=tawjihi
DATABASE_URL=postgresql+asyncpg://tawjihi:tawjihi_secure_pwd_2026@db:5432/tawjihi

# MongoDB
MONGO_INITDB_ROOT_USERNAME=tawjihi
MONGO_INITDB_ROOT_PASSWORD=tawjihi_mongo_pwd_2026
MONGODB_URL=mongodb://tawjihi:tawjihi_mongo_pwd_2026@mongo:27017/tawjihi?authSource=admin

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=tawjihi_minio
MINIO_ROOT_PASSWORD=tawjihi_minio_pwd_2026
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=tawjihi_minio
MINIO_SECRET_KEY=tawjihi_minio_pwd_2026

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — CHANGE THESE IN PRODUCTION!
JWT_SECRET=change-me-to-a-random-256-bit-value-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption (AES-256 for PII) — CHANGE IN PRODUCTION!
ENCRYPTION_KEY=change-me-to-a-random-256-bit-value-in-production

# AI — OpenRouter (single key for all LLM models)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# OpenAI (only needed for Whisper audio transcription, optional)
OPENAI_API_KEY=sk-your-openai-api-key-here

# WhatsApp Business API (optional)
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-id

# Email — Resend (optional)
RESEND_API_KEY=re_your-resend-api-key

# PostHog Analytics (optional)
POSTHOG_API_KEY=phc_your-posthog-key

# App
APP_NAME=Tawjihi
APP_ENV=development
APP_DEBUG=true
BACKEND_URL=http://localhost:8089
FRONTEND_URL=http://localhost:3089

# Frontend (exposed via Vite)
VITE_API_URL=
VITE_APP_NAME=Tawjihi
